---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Footer from '../../components/static/Footer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries.map((entry: CollectionEntry<'blog'>) => ({
    // entry.id is "filename.md" — strip extension for the URL slug
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry }: { entry: CollectionEntry<'blog'> } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.description}>
  <nav class="site-nav">
    <a href="/blog">← Blog</a>
  </nav>
  <aside id="blog-menu" class="blog-aside"></aside>
  <article class="blog-article">
    <h1>{entry.data.title}</h1>
    <time>
      {entry.data.date.toLocaleDateString(entry.data.language ?? 'en', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
      })}
    </time>
    {entry.data.cover && (
      <img
        src={entry.data.cover}
        alt={entry.data.title}
        width="800"
        height="450"
        loading="eager"
        decoding="async"
        class="cover"
      />
    )}
    {entry.data.image_credit?.text && (
      <a href={entry.data.image_credit.url} class="credit">{entry.data.image_credit.text}</a>
    )}
    <div class="prose">
      <Content />
    </div>
  </article>
  <Footer />
</Base>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a').forEach(a => {
    if (a.href.startsWith('http')) {
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener noreferrer');
    }
  });
  const aside = document.getElementById('blog-menu');
  const headings = document.querySelector('.blog-article')?.querySelectorAll('h2');
  if (aside && headings?.length) {
    const ol = document.createElement('ol');
    headings.forEach(h => {
      h.id = h.textContent ?? '';
      const li = document.createElement('li');
      const a  = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent;
      li.appendChild(a);
      ol.appendChild(li);
    });
    aside.appendChild(ol);
  }
</script>

<style>
  .site-nav { padding: 1rem 10vw; border-bottom: 1px solid var(--border); }
  .site-nav a { color: var(--muted); text-decoration: none; font-size: 0.9rem; }
  .site-nav a:hover { color: var(--ink); }
  .blog-aside { position: sticky; top: 2rem; max-width: 220px; font-size: 0.85rem; padding: 1rem; }
  .blog-article {
    max-width: 60rem; margin: 0 auto; padding: 4rem 10vw;
    display: flex; flex-direction: column; gap: 1rem;
  }
  .blog-article h1 { font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 700; }
  time { font-size: 0.85rem; color: var(--muted); }
  .cover { width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius); }
  .credit { font-size: 0.8rem; color: var(--muted); text-align: center; }
  .prose { line-height: 1.7; }
  .prose p { max-width: 72ch; margin-bottom: 1em; font-size: 1.05rem; }
  .prose h2 { font-size: 1.5rem; margin: 2em 0 0.5em; font-weight: 700; }
  .prose img { max-width: 100%; border-radius: var(--radius); }
</style>
