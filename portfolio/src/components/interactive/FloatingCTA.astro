---
import type { Locale } from '../../types/i18n';
import { useTranslations } from '../../i18n/ui';
import { parentHref } from '../islands/solutions/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const href = parentHref(locale);
---

<a href={href} class="floating-cta">
  {t('solutions.cta')}
  <svg width="14" height="10" viewBox="0 0 16 10" fill="none" stroke="currentColor" stroke-width="1.6">
    <path d="M11 1 L15 5 L11 9 M15 5 H1"></path>
  </svg>
</a>

<style>
  .floating-cta {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 190;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 20px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    box-shadow: 0 10px 26px -14px var(--accent);
    opacity: 0.6;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .floating-cta:hover,
  .floating-cta:focus-visible {
    opacity: 1;
    transform: translateY(-2px);
  }
  @media (max-width: 640px) {
    .floating-cta {
      bottom: 14px;
      right: 14px;
      padding: 10px 16px;
    }
  }
</style>
