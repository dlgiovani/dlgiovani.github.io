---
import type { Locale } from '../../types/i18n';
// href overrides support pages whose slug differs per locale (e.g. /consulting vs /pt-br/consultoria)
interface Props { locale: Locale; enHref?: string; ptHref?: string }
const { locale, enHref: enOverride, ptHref: ptOverride } = Astro.props;

const pathname = Astro.url.pathname;
const enHref = enOverride ?? (locale === 'pt-br' ? pathname.replace(/^\/pt-br/, '') || '/' : pathname);
const ptHref = ptOverride ?? (locale === 'en' ? `/pt-br${pathname}` : pathname);
---

<div class="ltbar" id="ltbar">
  <button class="ltbar-theme" id="ltbar-theme-btn" aria-label="Toggle theme">☀</button>
  <span class="ltbar-sep">|</span>
  <a href={enHref} class:list={['ltbar-lang', { active: locale === 'en' }]}>English</a>
  <span class="ltbar-sep">·</span>
  <a href={ptHref} class:list={['ltbar-lang', { active: locale === 'pt-br' }]}>Português</a>
</div>

<script>
  const btn = document.getElementById('ltbar-theme-btn');
  const html = document.documentElement;

  const stored = localStorage.getItem('tweak_theme');
  if (stored) html.setAttribute('data-theme', stored);

  function syncIcon() {
    if (btn) btn.textContent = html.getAttribute('data-theme') === 'dark' ? '☽' : '☀';
  }
  syncIcon();

  btn?.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('tweak_theme', next);
    syncIcon();
  });

  const enLink = document.querySelector('.ltbar-lang:not([href*="pt-br"])');
  const ptLink = document.querySelector('.ltbar-lang[href*="pt-br"]');

  enLink?.addEventListener('click', () => localStorage.setItem('lang_pref', 'en'));
  ptLink?.addEventListener('click', () => localStorage.setItem('lang_pref', 'pt-br'));

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const fireflyEls = [btn, enLink, ptLink].filter((el): el is Element => el !== null);
    let step = 0;
    const totalSteps = fireflyEls.length * 3;
    const fireflyInterval = setInterval(() => {
      fireflyEls.forEach(el => el.classList.remove('ltbar-firefly'));
      if (step >= totalSteps) {
        clearInterval(fireflyInterval);
        return;
      }
      fireflyEls[step % fireflyEls.length].classList.add('ltbar-firefly');
      step++;
    }, 700);
  }
</script>

<style>
  .ltbar {
    position: fixed;
    top: 55px;
    right: 16px;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-family: var(--mono);
    background: var(--paper);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .ltbar-theme {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    padding: 0;
    color: var(--ink);
    line-height: 1;
  }
  .ltbar-lang {
    color: var(--muted);
    text-decoration: none;
  }
  .ltbar-lang:hover,
  .ltbar-lang.active {
    color: var(--ink);
    font-weight: 600;
  }
  .ltbar-sep { color: var(--muted); }

  .ltbar-theme,
  .ltbar-lang {
    transition: color 0.6s ease-in-out, text-shadow 0.6s ease-in-out;
  }

  .ltbar-firefly {
    color: var(--accent) !important;
    text-shadow: 0 0 6px color-mix(in oklch, var(--accent) 65%, transparent);
  }
</style>
