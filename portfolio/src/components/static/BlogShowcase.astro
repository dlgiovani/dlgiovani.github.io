---
import { getCollection } from 'astro:content';

interface Props { qty?: number }
const { qty = 4 } = Astro.props;

const entries = await getCollection('blog');
const posts = entries
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, qty < 0 ? entries.length : qty);
---

<div class="blog-grid">
  {posts.map(entry => (
    <a href={`/blog/${entry.id.replace(/\.md$/, '')}/`} class="blog-card">
      <img
        src={entry.data.cover}
        alt={entry.data.title}
        width="400"
        height="225"
        loading="lazy"
        decoding="async"
      />
      <div class="blog-card-body">
        <h3>{entry.data.title}</h3>
        <p>{entry.data.description}</p>
        <time>
          {entry.data.date.toLocaleDateString(entry.data.language ?? 'en', {
            year: 'numeric', month: 'long', day: 'numeric',
          })}
        </time>
      </div>
    </a>
  ))}
</div>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 640px)  { .blog-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .blog-grid { grid-template-columns: repeat(4, 1fr); } }

  .blog-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: box-shadow 0.2s;
  }
  .blog-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.12); }
  .blog-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
  .blog-card-body { padding: var(--space-md); display: flex; flex-direction: column; gap: var(--space-xs); flex: 1; }
  .blog-card-body h3 {
    font-size: 1rem; font-weight: 600; margin: 0;
    overflow: hidden; text-overflow: ellipsis;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }
  .blog-card-body p {
    font-size: 0.875rem; color: var(--muted); margin: 0; flex: 1;
    overflow: hidden; text-overflow: ellipsis;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
  }
  time { font-size: 0.75rem; color: var(--muted); margin-top: auto; }
</style>
