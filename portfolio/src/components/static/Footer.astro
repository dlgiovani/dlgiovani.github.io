---
import { execSync } from 'node:child_process';
import type { Locale } from '../../types/i18n';
import { useTranslations } from '../../i18n/ui';
import { person } from '../../config/person';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const year = new Date().getFullYear();
let lastCommitAgo = '?';
try {
  lastCommitAgo = execSync('git log -1 --format="%ad" --date=format:"%Y-%m-%d"').toString().trim();
} catch { /* no-op */ }
---

<footer class="footer">
  <div class="big">
    {t('footer.cta_prefix')}<em>{t('footer.cta_em')}</em><br/>{t('footer.cta_suffix')}
  </div>
  <div class="small">
    <a href={`mailto:${person.email}`}>{person.email}</a>
    <a href={person.links.github} target="_blank" rel="noopener noreferrer">github / {person.handle}</a>
    <a href={person.links.linkedin} target="_blank" rel="noopener noreferrer">linkedin / {person.handle}</a>
  </div>

  <div class="colophon">
    <span>© {year} dlgiovani.dev · {t('footer.made_with')}</span>
    <span>{t('footer.last_commit')} · {lastCommitAgo}</span>
  </div>
</footer>

<style>
  .footer {
    padding: 80px var(--pad-x) 56px;
    border-top: var(--border);
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    align-items: end;
    max-width: 1480px;
    margin: 0 auto;
  }
  .footer .big {
    grid-column: 1 / 3;
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .footer .big em { font-style: italic; color: var(--accent); }
  .footer .small a {
    color: var(--ink);
    text-decoration: none;
    display: block;
    padding: 4px 0;
  }
  .footer .small a:hover { color: var(--accent); }
  .footer .colophon {
    grid-column: 1 / -1;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px dashed var(--line);
    display: flex;
    justify-content: space-between;
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .footer { grid-template-columns: 1fr; gap: 24px; align-items: start; }
    .footer .big { grid-column: 1; }
    .footer .colophon { flex-direction: column; gap: 6px; }
  }
</style>
