---
import '../styles/base.css';
import FloatingCTA from '../components/interactive/FloatingCTA.astro';
import { siteUrl, siteName } from '../config/site';
import { siteTheme, headlineFonts } from '../config/theme';
import type { Locale } from '../types/i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
}

const {
  title,
  description = 'Software engineer working at the seams between systems · dlgiovani',
  locale = 'en',
  ogImage = '/og-image.png',
} = Astro.props;

const pageTitle = title ? `${title} — dlgiovani.dev` : 'dlgiovani.dev — portfolio';
const canonicalEn = siteUrl + '/';
const canonicalPt = siteUrl + '/pt-br/';

const path = Astro.url.pathname;
const onSolutionsPage = path.startsWith('/consulting') || path.startsWith('/pt-br/consultoria');
---

<!doctype html>
<html lang={locale} data-theme={siteTheme.defaultTheme} data-density={siteTheme.defaultDensity}
      style={`--accent:${siteTheme.defaultAccent};--serif:${headlineFonts[siteTheme.defaultHeadlineFont]};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        if (localStorage.getItem('lang_pref')) return;
        var onPt = location.pathname.startsWith('/pt-br');
        if (!onPt && navigator.language && navigator.language.toLowerCase().startsWith('pt')) {
          localStorage.setItem('lang_pref', 'pt-br');
          location.replace('/pt-br' + location.pathname);
        } else {
          localStorage.setItem('lang_pref', onPt ? 'pt-br' : 'en');
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- OG -->
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={siteUrl + ogImage} />
    <meta property="og:type"        content="website" />
    <meta name="twitter:card"       content="summary_large_image" />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en"        href={canonicalEn} />
    <link rel="alternate" hreflang="pt-BR"      href={canonicalPt} />
    <link rel="alternate" hreflang="x-default" href={canonicalEn} />

    <link rel="icon" type="image/png" href="/icon-32.png" />
    <link rel="apple-touch-icon"      href="/icon-180.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    {!onSolutionsPage && <FloatingCTA locale={locale} />}
  </body>
</html>
