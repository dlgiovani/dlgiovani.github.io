---
import '../styles/base.css';
import FloatingCTA from '../components/interactive/FloatingCTA.astro';
import { siteUrl, siteName } from '../config/site';
import { siteTheme, headlineFonts } from '../config/theme';
import { altHrefs, isPtPath } from '../lib/locale-paths';
import { parentHref } from '../components/islands/solutions/routes';
import type { Locale } from '../types/i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
  // Counterpart URL in each language. Defaults to a /pt-br prefix swap; pages
  // whose slug differs per locale (e.g. work-with-me) pass explicit values.
  altEn?: string;
  altPt?: string;
  // Whether this page has a counterpart in the other language. Single-language
  // pages (e.g. blog posts) set false so the sticky-language redirect skips them.
  mirrored?: boolean;
  // Hostname prefix under which this page is a subdomain's landing page (nginx
  // 301s the subdomain root here), making its language ambiguous like '/'.
  subdomainRoot?: string;
}

const {
  title,
  description = 'Software engineer working at the seams between systems · dlgiovani',
  locale = 'en',
  ogImage = '/og-image.png',
  altEn: altEnProp,
  altPt: altPtProp,
  mirrored = true,
  subdomainRoot = '',
} = Astro.props;

const pageTitle = title ? `${title} — dlgiovani.dev` : 'dlgiovani.dev — portfolio';
const path = Astro.url.pathname;
const defaults = altHrefs(path);
const onPt = isPtPath(path);
const altEn = altEnProp ?? defaults.en;
const altPt = altPtProp ?? defaults.pt;
const isRoot = path === '/';
const onSolutionsPage = path.startsWith(parentHref('en')) || path.startsWith(parentHref('pt-br'));
---

<!doctype html>
<html lang={locale} data-theme={siteTheme.defaultTheme} data-density={siteTheme.defaultDensity}
      style={`--accent:${siteTheme.defaultAccent};--serif:${headlineFonts[siteTheme.defaultHeadlineFont]};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline define:vars={{ altEn, altPt, mirrored, onPt, isRoot, subdomainRoot }}>
      // Language resolution: an explicit choice (lang_choice, written only by
      // the toggle) wins and is enforced by redirecting mismatched pages to
      // their counterpart. With no choice yet, the URL's language stands —
      // except language-ambiguous entry points (the root, or a subdomain's
      // landing page), which fall back to the browser language. Redirects use
      // replace() so switching never piles onto the back stack.
      (function () {
        // Pre-2026-07 code auto-wrote lang_pref without user action; it must
        // not be honored as an explicit choice.
        localStorage.removeItem('lang_pref');
        function go(target) { location.replace(target + location.search + location.hash); }
        function enforce() {
          var pref = localStorage.getItem('lang_choice');
          if (mirrored && pref === 'pt-br' && !onPt) { go(altPt); return; }
          if (mirrored && pref === 'en' && onPt) { go(altEn); return; }
          var ambiguous = isRoot || (subdomainRoot && location.hostname.indexOf(subdomainRoot) === 0);
          if (!pref && !onPt && ambiguous &&
              navigator.language && navigator.language.toLowerCase().indexOf('pt') === 0) {
            go(altPt);
          }
        }
        enforce();
        // Pages restored from the back/forward cache don't re-run inline scripts.
        window.addEventListener('pageshow', function (e) { if (e.persisted) enforce(); });
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- OG -->
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={siteUrl + ogImage} />
    <meta property="og:type"        content="website" />
    <meta name="twitter:card"       content="summary_large_image" />

    <!-- hreflang -->
    {mirrored && (
      <>
        <link rel="alternate" hreflang="en"        href={siteUrl + altEn} />
        <link rel="alternate" hreflang="pt-BR"      href={siteUrl + altPt} />
        <link rel="alternate" hreflang="x-default" href={siteUrl + altEn} />
      </>
    )}

    <link rel="icon" type="image/png" href="/icon-32.png" />
    <link rel="apple-touch-icon"      href="/icon-180.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    {!onSolutionsPage && <FloatingCTA locale={locale} />}
  </body>
</html>
