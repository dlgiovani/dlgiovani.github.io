---
import Base from '../../../layouts/Base.astro';
import LangThemeBar from '../../../components/interactive/LangThemeBar.astro';
import { SolutionsChooser } from '../../../components/islands/solutions/SolutionsChooser';
import pt from '../../../i18n/locales/pt-br';

const locale = 'pt-br';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Base title={pt.solutions.page_title} description={pt.solutions.page_desc} locale={locale}>
  <SolutionsChooser client:load strings={pt.solutions} apiUrl={apiUrl} homeHref="/pt-br/" />
  <LangThemeBar locale={locale} enHref="/consulting" ptHref="/pt-br/consultoria" />
</Base>
