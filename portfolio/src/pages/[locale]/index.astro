---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/interactive/Hero.astro';
import Ticker from '../../components/interactive/Ticker.astro';
import About from '../../components/static/About.astro';
import Work from '../../components/static/Work.astro';
import CodeSection from '../../components/static/CodeSection.astro';
import Signals from '../../components/interactive/Signals.astro';
import Footer from '../../components/static/Footer.astro';
import { Playground } from '../../components/islands/playground/Playground';
import LangThemeBar from '../../components/interactive/LangThemeBar.astro';
import { WEATHER_EFFECTS } from '../../config/pokemon';
import { siteTheme } from '../../config/theme';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../types/i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'pt-br' } }];
}

const { locale } = Astro.params as { locale: Locale };
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
const t = useTranslations(locale);
const pgStrings = {
  kicker:          t('playground.kicker'),
  title_1:         t('playground.title_1'),
  title_2:         t('playground.title_2'),
  title_em:        t('playground.title_em'),
  lead:            t('playground.lead'),
  tab_weather:     t('playground.tab_weather'),
  tab_map:         t('playground.tab_map'),
  step_pokemon:    t('playground.step_pokemon'),
  step_city:       t('playground.step_city'),
  save_label:      t('playground.save_label'),
  save_done:       t('playground.save_done'),
  loading_pokemon: t('playground.loading_pokemon'),
  map_title:       t('playground.map_title'),
  map_loading:     t('playground.map_loading'),
  map_empty_list:  t('playground.map_empty_list'),
  map_empty_map:      t('playground.map_empty_map'),
  map_top:            t('playground.map_top'),
  map_top_picks:      t('playground.map_top_picks'),
  card_no_wx_effect:  t('playground.card_no_wx_effect'),
  card_basic:         t('playground.card_basic'),
  card_boosted_by:    t('playground.card_boosted_by'),
  card_opener:        t('playground.card_opener'),
  card_weakness:      t('playground.card_weakness'),
  card_retreat:       t('playground.card_retreat'),
  card_specimen:      t('playground.card_specimen'),
  card_move_strike_suffix: t('playground.card_move_strike_suffix'),
  card_move_tackle:        t('playground.card_move_tackle'),
  pick_prompt:        t('playground.pick_prompt'),
  pokemon_placeholder: t('playground.pokemon_placeholder'),
  city_placeholder:   t('playground.city_placeholder'),
  weather_kind_label: {
    sunny: t('playground.weather_kind_label.sunny'),
    rain: t('playground.weather_kind_label.rain'),
    cloudy: t('playground.weather_kind_label.cloudy'),
    snow: t('playground.weather_kind_label.snow'),
    wind: t('playground.weather_kind_label.wind'),
    clear_night: t('playground.weather_kind_label.clear_night'),
  },
  weather_desc: {
    clear: t('playground.weather_desc.clear'),
    mainly_clear: t('playground.weather_desc.mainly_clear'),
    partly_cloudy: t('playground.weather_desc.partly_cloudy'),
    overcast: t('playground.weather_desc.overcast'),
    foggy: t('playground.weather_desc.foggy'),
    drizzle: t('playground.weather_desc.drizzle'),
    rain: t('playground.weather_desc.rain'),
    freezing_rain: t('playground.weather_desc.freezing_rain'),
    snow: t('playground.weather_desc.snow'),
    snow_grains: t('playground.weather_desc.snow_grains'),
    rain_showers: t('playground.weather_desc.rain_showers'),
    snow_showers: t('playground.weather_desc.snow_showers'),
    thunderstorm: t('playground.weather_desc.thunderstorm'),
    cloudy: t('playground.weather_desc.cloudy'),
  },
  weather_mood: {
    sunny: t('playground.weather_mood.sunny'),
    rain: t('playground.weather_mood.rain'),
    cloudy: t('playground.weather_mood.cloudy'),
    snow: t('playground.weather_mood.snow'),
    wind: t('playground.weather_mood.wind'),
    clear_night: t('playground.weather_mood.clear_night'),
  },
};
---

<Base title={undefined} locale={locale}>
  <Ticker locale={locale} />
  <Hero locale={locale} />
  <About locale={locale} />
  <Work locale={locale} />
  <CodeSection locale={locale} />

  <div id="playground-mount">
    <Playground
      client:visible
      weatherEffects={WEATHER_EFFECTS}
      apiUrl={apiUrl}
      cardStyle={siteTheme.defaultCardStyle}
      strings={pgStrings}
      locale={locale}
    />
  </div>

  <Signals locale={locale} />
  <Footer locale={locale} />

  <LangThemeBar locale={locale} />
</Base>
